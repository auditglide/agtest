# Copy to .env.local and fill in before running tests

# Frontend base URL
BASE_URL=http://localhost:5173

# Backend API (used by seed helpers, not the browser)
API_URL=https://devapi.auditglide.com

# Optional DB tunnel URL for onboarding token fixtures (ON-7 / ON-8).
# Example when using your SSH tunnel on localhost:5433:
# TEST_DB_URL=postgresql://postgres:postgres@127.0.0.1:5433/AGDev?connection_limit=1
TEST_DB_URL=

# Admin credentials (existing test user — must have all permissions)
TEST_ADMIN_EMAIL=admin@yourfirm.com
TEST_ADMIN_PASSWORD=YourPassword123

# Dedicated disposable user for account-lockout testing (A7)
# The suite intentionally locks this account after repeated bad passwords.
TEST_DEADLOCK_EMAIL=
TEST_DEADLOCK_PASSWORD=

# Onboarding tests — set the verification code when you receive it by email
# Leave blank to pause the test and enter the code manually in the browser
ONBOARDING_EMAIL=
ONBOARDING_VERIFICATION_CODE=

# Low-permission user for access-control tests (all permissions false)
TEST_READONLY_EMAIL=
TEST_READONLY_PASSWORD=
